---
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/sections/Footer.astro";
import "@/styles/global.css";

interface Props {
	title: string;
	description: string;
}

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Inter:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
		<meta name="description" content={description} />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
	</head>
	<body class="w-full sm:max-w-3/4 lg:max-w-3/5 m-auto pt-6 px-6 sm:px-0">
		<header class="sticky top-0 z-50 flex justify-end py-4 mb-10">
			<Navbar />
		</header>
		<slot />
		<Footer />
	</body>
</html>
