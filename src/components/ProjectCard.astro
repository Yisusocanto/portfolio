---
import Chip from "@/components/ui/Chip.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

interface Props {
	slug: string;
	title: string;
	description: string;
	techs: string[];
	imageUrl: any;
	type: string;
	reverse?: boolean;
}

const {
	description,
	imageUrl,
	techs,
	title,
	slug,
	type,
	reverse = false,
} = Astro.props;
---

<div
	class="grid grid-cols-1 md:grid-cols-12 gap-y-6 md:gap-y-0 items-center w-full relative group select-none">
	<!-- Dark Image Card -->
	<a
		href={`/projects/${slug}`}
		class:list={[
			"bg-inverse aspect-16/10 flex items-center justify-center z-0 transition-transform duration-500 ease-out hover:scale-[1.01] md:row-start-1 border shadow-md",
			reverse ? "md:col-start-5 md:col-end-13" : "md:col-start-1 md:col-end-9",
		]}>
		<Image
			src={imageUrl}
			alt={`Imagen de ${title}`}
			class="max-w-full max-h-full object-contain filter brightness-95 group-hover:brightness-100 transition-all duration-500"
		/>
	</a>

	<!-- Overlapping White Text Card -->
	<div
		class:list={[
			"bg-surface p-6 sm:p-10 md:p-12 border border-brand/10 shadow-2xl z-10 w-full flex flex-col justify-center md:row-start-1 transition-all duration-500 text-secondary",
			reverse
				? "md:col-start-1 md:col-end-7 md:text-start"
				: "md:col-start-7 md:col-end-13 text-start",
		]}>
		<span
			class="text-[10px] tracking-[0.3em] font-semibold font-sfuidisplay uppercase mb-4 block opacity-60">
			{type}
		</span>
		<h2
			class="text-3xl sm:text-4xl md:text-5xl font-normal font-neuehaasdisplay mb-6 uppercase tracking-tighter leading-none">
			<a href={`/projects/${slug}`} class="hover:opacity-70 transition-opacity">
				{title}
			</a>
		</h2>
		<p
			class="mb-8 text-base sm:text-lg font-sfuidisplay font-light leading-relaxed opacity-90">
			{description}
		</p>
		<!-- Tech stack empty outline circles -->
		<div class="flex gap-2 flex-wrap">
			{
				techs.map((tech) => (
					<Chip icon={tech.replace(" ", "").toLowerCase()}>{tech}</Chip>
				))
			}
		</div>
	</div>
</div>
