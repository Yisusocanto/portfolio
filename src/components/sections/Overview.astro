---
import { Image } from "astro:assets";
import Chip from "../ui/Chip.astro";
import Separator from "@/components/ui/Separator.astro";
import MiImagen from "@/assets/mi-foto.jpg";

const stacks = [
	"Next.js/React",
	"FastAPI/Python",
	"Flask/Python",
	"PostgreSQL/SQL",
	"Mongoose/noSQL",
	"Tailwind CSS",
];
---

<section
	class="flex flex-col lg:flex-row gap-12 lg:gap-20 justify-between items-center px-6 lg:px-0">
	<div class="w-full max-w-[400px] lg:max-w-none lg:flex-1">
		<Image
			alt="Jesus profile picture"
			src={MiImagen}
			width={500}
			height={500}
			class="rounded-3xl shadow-xl w-full h-auto"
		/>
	</div>
	<div class="flex flex-col gap-6 lg:flex-2">
		<h3 class="text-2xl font-bold">OVERVIEW</h3>
		<Separator />
		<p
			>My technical approach focuses on eliminating unnecessary complexity. I treat every line of code as a structural element, prioritizing maintainability, performance, and legibility.</p
		>
		<p
			>I build systems that scale, interfaces that get out of the way, and solutions that solve real-world problems with mathematical elegance.</p
		>
	</div>
</section>
