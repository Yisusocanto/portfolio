---
import ProjectCard from "@/components/ProjectCard.astro";
import Separator from "@/components/ui/Separator.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const principalProjects = projects.slice(0, 4);
---

<section class="py-10">
	<div class="mb-14">
		<div
			class="flex flex-col sm:flex-row justify-between items-baseline gap-2 mb-3"
		>
			<h3
				class="text-5xl sm:text-7xl md:text-display-lg font-normal uppercase tracking-tighter leading-none"
				>PROJECTS</h3>
		</div>
		<Separator />
	</div>
	<div class="flex flex-col gap-24 md:gap-40">
		{
			principalProjects.map((project, i) => (
				<ProjectCard
					title={project.data.title}
					description={project.data.description}
					imageUrl={project.data.imageUrl}
					techs={project.data.techs}
					type={project.data.type}
					slug={project.id}
					reverse={i % 2 != 0}
				/>
			))
		}
	</div>
</section>
