---
import { Icon } from "astro-icon/components";

interface Props {
	icon?: string;
}

const { icon } = Astro.props;
---

<span
	class="flex min-w-fit max-w-fit items-center gap-3 border border-primary/15 bg-primary/5 px-4 py-2.5 text-xs font-semibold uppercase tracking-wider text-primary transition-all duration-300 hover:bg-primary hover:text-on-primary"
>
	{icon && <Icon name={icon} class="h-4 w-4" />}
	<slot />
</span>
