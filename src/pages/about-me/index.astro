---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import MiPhoto from "@/assets/mi-foto.jpg";
import Separator from "@/components/ui/Separator.astro";
---

<Layout title="About me" description="Learn who I am and what I value.">
	<main class="flex flex-col gap-12 px-6 sm:px-0 mb-20">
		<section
			class="flex flex-col md:flex-row gap-10 md:gap-20 items-center md:items-start pt-10">
			<div class="flex-2 order-2 md:order-1 w-full">
				<h1
					class="text-5xl sm:text-7xl md:text-8xl lg:text-display leading-none mb-4 tracking-tighter uppercase">
					JESUS <br /> OCANTO
				</h1>
				<h2
					class="text-3xl sm:text-4xl md:text-6xl lg:text-display-lg text-primary opacity-80 mb-10 uppercase">
					Who am I?
				</h2>

				<div
					class="flex flex-col gap-6 text-xl sm:text-2xl leading-relaxed max-w-2xl font-light">
					<p>
						Hi! I'm <strong class="font-bold text-primary"
							>Jesús Ocanto</strong
						>, a Full Stack Developer passionate about building web applications that not only work perfectly but also feel incredible to use.
					</p>
					<p>
						I specialize in managing the entire product lifecycle: from designing robust and fast backend databases to polishing every visual detail on the frontend for a fully responsive experience.
					</p>
				</div>
			</div>

			<div
				class="flex-1 order-1 md:order-2 w-full max-w-[280px] sm:max-w-[350px] md:max-w-[450px] py-6 md:py-10">
				<div class="relative group">
					<div
						class="absolute inset-0 bg-primary/10 rounded-[60px] translate-x-6 translate-y-6 transition-transform duration-500 group-hover:translate-x-4 group-hover:translate-y-4">
					</div>
					<div
						class="absolute inset-0 border-2 border-primary/20 rounded-[60px] -translate-x-4 -translate-y-4 transition-transform duration-500 group-hover:-translate-x-2 group-hover:-translate-y-2">
					</div>

					<div
						class="relative overflow-hidden rounded-[50px] aspect-4/5 shadow-2xl">
						<Image
							src={MiPhoto}
							alt="Jesús Ocanto"
							class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 scale-110 group-hover:scale-100"
						/>
						<div
							class="absolute inset-0 bg-primary/20 group-hover:bg-transparent transition-colors duration-500"></div>
					</div>
				</div>
			</div>
		</section>

		<section class="mt-20">
			<h2
				class="text-heading font-bold uppercase tracking-[0.2em] mb-4 text-primary/60">
				Philosophy & Stack
			</h2>
			<Separator />
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-12">
				<div class="space-y-4">
					<p class="text-2xl leading-tight font-medium text-primary">
						Code should be clean, scalable, and solve real-world problems.
					</p>
					<p class="text-lg leading-relaxed opacity-80">
						I love speed and modularity, which is why my trusted stack includes modern tools like <strong
							>React, Next.js and Astro</strong
						> to create stunning, highly optimized interfaces.
					</p>
				</div>
				<div class="space-y-4">
					<p class="text-lg leading-relaxed opacity-80">
						I use <strong>Tailwind CSS</strong> for styling, combined with the power and structure of <strong>FastAPI and SQLModel</strong> on the backend. I don't shy away from heavy logic; on the contrary, I am motivated by structuring clean architectures that streamline development processes.
					</p>
				</div>
			</div>
		</section>

		<section
			class="relative overflow-hidden bg-primary text-on-primary p-10 sm:p-20 rounded-[60px] mt-20">
			<h2
				class="text-4xl md:text-5xl text-on-primary font-bold mb-10 tracking-tight">
				Who am I when I'm not writing code?
			</h2>
			<p
				class="text-xl md:text-3xl leading-snug opacity-90 font-light italic text-balance">
				"When I'm not caught in a coding loop or wrestling with an API, you'll probably find me analyzing the narrative of an open-world video game, listening to music with the highest audio fidelity possible, or enjoying a good coffee in some cool spot in the city."
			</p>
		</section>
	</main>
</Layout>
