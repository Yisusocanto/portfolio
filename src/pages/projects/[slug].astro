---
import Prose from "@/components/Prose.astro";
import Layout from "@/layouts/Layout.astro";
import { render } from "astro:content";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
	const projects = await getCollection("projects");

	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout 
	title={`${project.data.title} | Project by Jesús Ocanto`} 
	description={project.data.description}
>
	<main class="px-6 sm:px-0 mb-20">
		<Prose
			class="mt-10 prose dark:prose-invert prose-h1:text-6xl prose-h1:md:text-8xl prose-h1:lg:text-display prose-h1:mb-12 prose-h1:tracking-tighter prose-h1:uppercase prose-p:text-xl prose-p:leading-relaxed prose-headings:text-primary max-w-none prose-img:rounded-3xl prose-img:shadow-2xl prose-img:w-full prose-img:h-auto prose-img:my-12"
		>
			<Content />
		</Prose>
	</main>
</Layout>
