---
import Prose from "@/components/Prose.astro";
import Layout from "@/layouts/Layout.astro";
import { render } from "astro:content";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
	const projects = await getCollection("projects");

	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.title} description={project.data.description}>
	<Prose
		class="mt-10 px-4 prose dark:prose-invert prose-h1:md:text-display-lg prose-h1:xg:text-display prose-h1:text-6xl prose-h1:mb-0 prose-p:text-primary prose-headings:text-primary max-w-none prose-img:w-full prose-img:h-48 prose-img:sm:h-64 prose-img:md:h-80 prose-img:lg:h-[380px]"
	>
		<Content />
	</Prose>
</Layout>
